# Malaria LLM-CDSS — Environment Variables
# Copy this file to .env and fill in your API keys.
# Fallback chain: Groq → Anthropic → OpenAI → rule-based template
# At least one key is required for LLM explanations.

# Primary LLM — Groq (fastest, free tier available)
groq_api_key=your_groq_key_here
groq_model=llama-3.1-8b-instant

# Secondary LLM — Anthropic Claude
anthropic_api_key=

# Tertiary LLM — OpenAI
openai_api_key=
